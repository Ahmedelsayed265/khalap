{% set default_items = [
    {
        'quote': 'اللوحة غيّرت شكل الصالة بالكامل، جودة الطباعة فاقت التوقعات والتغليف كان محترم جداً.',
        'name': 'محمد العتيبي',
        'role': 'مهندس مدني'
    },
    {
        'quote': 'طلبت لوحة مخصصة لصورتي، التنسيق مع الفريق كان سهل والنتيجة طلعت أجمل مما تخيلت.',
        'name': 'فيصل الحربي',
        'role': 'صاحب مكتب'
    },
    {
        'quote': 'ألوان اللوحة متناسقة مع ديكور البيت، والتوصيل كان سريع. أنصح فيها بدون تردد.',
        'name': 'ريم الشمري',
        'role': 'ربة منزل'
    },
    {
        'quote': 'خلاب فهم ذوقي من أول محادثة، واللوحة صارت أجمل قطعة في المدخل.',
        'name': 'عبدالله القحطاني',
        'role': 'مهندس معماري'
    }
] %}

{% set section_title = settings.title or 'لوحة تبدأ بقصة… وتنتهي بتجربة لا تُنسى' %}
{% set email_placeholder = settings.email_placeholder or 'أدخل بريدك الإلكتروني هنا' %}
{% set form_action = settings.form_action or '/newsletter' %}
{% set testimonial_items = settings.items if settings.items | length > 0 else default_items %}
{% set card_positions = ['tl', 'tr', 'bl', 'br'] %}

<section
    id="{{ sectionId }}"
    section-id="{{ sectionId }}"
    class="khalab-testimonials khalab-section-solid"
    aria-label="{{ section_title }}"
>
    <div class="khalab-testimonials-inner">
        <header class="khalab-testimonials-header">
            <h2 class="khalab-testimonials-title">{{ section_title }}</h2>

            <form class="khalab-testimonials-subscribe" action="{{ form_action }}" method="post">
                <label class="visually-hidden" for="{{ sectionId }}-email">{{ email_placeholder }}</label>
                <input
                    id="{{ sectionId }}-email"
                    type="email"
                    name="email"
                    class="khalab-testimonials-subscribe-input"
                    placeholder="{{ email_placeholder }}"
                    required
                    autocomplete="email"
                >
                <button type="submit" class="khalab-testimonials-subscribe-btn" aria-label="{{ _('Subscribe') }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12H19M12 5L19 12L12 19"/>
                    </svg>
                </button>
            </form>
        </header>

        <div class="khalab-testimonials-stage">
            <div class="khalab-testimonials-spotlight" aria-hidden="true"></div>

            {% if settings.center_image %}
                <picture class="khalab-testimonials-figure-wrap">
                    {% if settings.center_image_mobile %}
                        <source media="(max-width: 768px)" srcset="{{ settings.center_image_mobile }}">
                    {% endif %}
                    <img
                        src="{{ settings.center_image }}"
                        alt=""
                        class="khalab-testimonials-figure"
                        loading="lazy"
                    >
                </picture>
            {% endif %}

            {% for item in testimonial_items[:4] %}
                {% set card_pos = card_positions[loop.index0] %}
                <article class="khalab-testimonials-card khalab-testimonials-card--{{ card_pos }}">
                    <div class="khalab-testimonials-card-quote-wrap">
                        <span class="khalab-testimonials-card-quote-mark khalab-testimonials-card-quote-mark--open" aria-hidden="true">“</span>
                        <p class="khalab-testimonials-card-quote">{{ item.quote }}</p>
                        <span class="khalab-testimonials-card-quote-mark khalab-testimonials-card-quote-mark--close" aria-hidden="true">”</span>
                    </div>
                    <div class="khalab-testimonials-card-footer">
                        <div class="khalab-testimonials-card-author">
                            {% if item.avatar %}
                                <img src="{{ item.avatar }}" alt="" class="khalab-testimonials-card-avatar" loading="lazy">
                            {% else %}
                                <span class="khalab-testimonials-card-avatar khalab-testimonials-card-avatar--placeholder" aria-hidden="true"></span>
                            {% endif %}
                            <div class="khalab-testimonials-card-meta">
                                <span class="khalab-testimonials-card-name">{{ item.name }}</span>
                                {% if item.role %}
                                    <span class="khalab-testimonials-card-role">{{ item.role }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="khalab-testimonials-card-stars" aria-hidden="true">
                            {% for i in range(5) %}
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <g clip-path="url(#clip0_1352_1051)">
                                    <path d="M5.7245 5.48802L7.4565 2.00002C7.5069 1.89908 7.58444 1.81418 7.68044 1.75484C7.77637 1.6955 7.88697 1.66406 7.99984 1.66406C8.11264 1.66406 8.22324 1.6955 8.31924 1.75484C8.41524 1.81418 8.49277 1.89908 8.54317 2.00002L10.2752 5.48802L14.1472 6.05069C14.2588 6.06618 14.3639 6.11275 14.4504 6.1851C14.5369 6.25744 14.6013 6.35265 14.6362 6.45984C14.6712 6.56704 14.6754 6.68193 14.6482 6.79133C14.621 6.90073 14.5636 7.00033 14.4825 7.07866L11.6812 9.792L12.3425 13.6253C12.4272 14.1173 11.9072 14.492 11.4625 14.26L7.99984 12.4493L4.5365 14.26C4.0925 14.4927 3.5725 14.1173 3.65716 13.6247L4.3185 9.79133L1.51716 7.078C1.43649 6.9996 1.37943 6.90013 1.35248 6.79093C1.32552 6.68166 1.32975 6.56707 1.36468 6.46012C1.39961 6.35318 1.46384 6.25817 1.55008 6.18591C1.63631 6.11366 1.74109 6.06704 1.8525 6.05136L5.7245 5.48802Z" fill="#FAFF35" stroke="#FAFF35" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </g>
                                    <defs>
                                    <clipPath id="clip0_1352_1051">
                                    <rect width="16" height="16" fill="white"/>
                                    </clipPath>
                                    </defs>
                                </svg>
                            {% endfor %}
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
