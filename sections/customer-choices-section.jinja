{% set default_items = [
    {'label': 'مختارة بعناية', 'rating': '5', 'price': '200', 'compare_price': '1070.5', 'url': '/products'},
    {'label': 'الأكثر طلباً', 'rating': '5', 'price': '200', 'compare_price': '1070.5', 'url': '/products'},
    {'label': 'الأعلى تقييماً', 'rating': '4', 'price': '200', 'compare_price': '1070.5', 'url': '/products'}
] %}
{% set cms_items = safeget(settings, 'items', []) %}
{% set choice_items = cms_items if cms_items | length > 0 else default_items %}
{% set section_title = settings.title or 'لوحات اختارها عملاء خلاب بكثرة، مناسبة لمن يبحث عن خيارات مضمونة وجاهزة.' %}
{% set cap_top = 'customer-choices-cap-top.png' | asset_url %}
{% set cap_bottom = 'customer-choices-cap-bottom.png' | asset_url %}

<section
    id="{{ sectionId }}"
    section-id="{{ sectionId }}"
    class="khalab-customer-choices khalab-section-solid"
    aria-label="{{ section_title }}">
    <div class="khalab-customer-choices-inner">
        <header class="khalab-customer-choices-header">
            <h2 class="khalab-customer-choices-title">{{ section_title }}</h2>
        </header>

        {% if choice_items | length > 0 %}
            <div class="khalab-customer-choices-stage">
                <div class="khalab-customer-choices-swiper swiper" role="region" aria-roledescription="carousel" aria-label="{{ section_title }}">
                    <div class="swiper-wrapper">
                        {% for item in choice_items %}
                            {% set raw_image = item.image %}
                            {% set image_src = '' %}
                            {% if raw_image %}
                                {% if raw_image is string %}
                                    {% set image_src = raw_image %}
                                {% elif raw_image.url is defined and raw_image.url %}
                                    {% set image_src = raw_image.url %}
                                {% elif raw_image.src is defined and raw_image.src %}
                                    {% set image_src = raw_image.src %}
                                {% elif raw_image.path is defined and raw_image.path %}
                                    {% set image_src = raw_image.path %}
                                {% elif raw_image.image is defined %}
                                    {% if raw_image.image is string %}
                                        {% set image_src = raw_image.image %}
                                    {% elif raw_image.image.url is defined %}
                                        {% set image_src = raw_image.image.url %}
                                    {% endif %}
                                {% endif %}
                            {% endif %}

                            {% set card_label = item.label or 'مختارة بعناية' %}
                            {% set card_url = item.url or '/products' %}
                            {% set card_price = item.price or '' %}
                            {% set card_compare = item.compare_price or '' %}
                            {% set card_rating = (item.rating | default('5')) | int %}
                            {% if card_rating < 0 %}
                                {% set card_rating = 0 %}
                            {% elif card_rating > 5 %}
                                {% set card_rating = 5 %}
                            {% endif %}
                            {% set is_lower = loop.index0 % 2 == 1 %}

                            <div class="swiper-slide khalab-customer-choices-slide{% if is_lower %} is-lower{% else %} is-higher{% endif %}">
                                <a href="{{ card_url }}" class="khalab-customer-choices-card">
                                    <span class="khalab-customer-choices-card-inner">
                                        <span class="khalab-customer-choices-card-media">
                                            {% if image_src %}
                                                <img
                                                    src="{{ image_url(image_src, w=876, q=90, f='auto') }}"
                                                    alt="{{ card_label }}"
                                                    class="khalab-customer-choices-card-photo"
                                                    loading="{% if loop.index0 < 2 %}eager{% else %}lazy{% endif %}"
                                                    draggable="false"
                                                >
                                            {% else %}
                                                <span class="khalab-customer-choices-card-placeholder" aria-hidden="true"></span>
                                            {% endif %}
                                        </span>

                                        <img
                                            src="{{ cap_top }}"
                                            alt=""
                                            class="khalab-customer-choices-card-cap khalab-customer-choices-card-cap--top"
                                            loading="{% if loop.index0 < 2 %}eager{% else %}lazy{% endif %}"
                                            draggable="false"
                                        >
                                        <img
                                            src="{{ cap_bottom }}"
                                            alt=""
                                            class="khalab-customer-choices-card-cap khalab-customer-choices-card-cap--bottom"
                                            loading="{% if loop.index0 < 2 %}eager{% else %}lazy{% endif %}"
                                            draggable="false"
                                        >

                                        <span class="khalab-customer-choices-card-head">
                                            <span class="khalab-customer-choices-card-label">{{ card_label | safe }}</span>
                                            {% if card_rating > 0 %}
                                                <span class="khalab-customer-choices-card-stars" aria-label="{{ card_rating }} / 5">
                                                    {% for star in range(1, 6) %}
                                                        <img
                                                            src="{{ 'iconoir_star-solid.svg' | asset_url }}"
                                                            alt=""
                                                            class="khalab-customer-choices-card-star{% if star > card_rating %} is-muted{% endif %}"
                                                            width="18"
                                                            height="18"
                                                            loading="lazy"
                                                            draggable="false"
                                                        >
                                                    {% endfor %}
                                                </span>
                                            {% endif %}
                                        </span>

                                        <span class="khalab-customer-choices-card-foot">
                                            <span class="khalab-customer-choices-card-prices">
                                                {% if card_price %}
                                                    <span class="khalab-customer-choices-card-price">{{ card_price }} 
                                                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                                                            <rect width="28" height="28" fill="url(#pattern0_2171_580)"/>
                                                            <defs>
                                                            <pattern id="pattern0_2171_580" patternContentUnits="objectBoundingBox" width="1" height="1">
                                                            <use xlink:href="#image0_2171_580" transform="matrix(0.00205339 0 0 0.00184805 0 -0.0026694)"/>
                                                            </pattern>
                                                            <image id="image0_2171_580" width="487" height="544" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
                                                            </defs>
                                                        </svg>
                                                    </span>
                                                {% endif %}
                                                {% if card_compare %}
                                                    <span class="khalab-customer-choices-card-compare">{{ card_compare }} 
                                                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
<rect width="20" height="20" fill="url(#pattern0_2171_582)" fill-opacity="0.43"/>
<defs>
<pattern id="pattern0_2171_582" patternContentUnits="objectBoundingBox" width="1" height="1">
<use xlink:href="#image0_2171_582" transform="matrix(0.00210084 0 0 0.00183824 -0.0115546 0)"/>
</pattern>
<image id="image0_2171_582" width="487" height="544" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
</defs>
</svg>
</span>
                                                {% endif %}
                                            </span>
                                        </span>
                                    </span>
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {% if choice_items | length > 1 %}
                    <button type="button" class="khalab-customer-choices-nav khalab-customer-choices-nav--prev" aria-label="{{ _('Previous') }}">
                        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" aria-hidden="true">
                            <path d="M8.5 1.5L1.5 9L8.5 16.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <button type="button" class="khalab-customer-choices-nav khalab-customer-choices-nav--next" aria-label="{{ _('Next') }}">
                        <svg width="10" height="18" viewBox="0 0 10 18" fill="none" aria-hidden="true">
                            <path d="M1.5 1.5L8.5 9L1.5 16.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                {% endif %}
            </div>
        {% endif %}
    </div>
</section>

<link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}">
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
<script src="{{ 'customer-choices-gallery.js' | asset_url }}" defer></script>
