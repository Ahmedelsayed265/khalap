<div id="sidenav-overlay" onclick="closeSlidingMenu()" aria-hidden="true"></div>
<nav class="slide-menu khalab-slide-menu menu-header-theme-bg-primary menu-header-theme-bg-primary-brightness-100" id="sliding-menu">
    {% if session.lang == 'ar' %}
        {% set slide_menu_title = 'القائمة' %}
    {% else %}
        {% set slide_menu_title = _('Menu') %}
    {% endif %}

    <div class="khalab-slide-menu-header">
        <h2 class="khalab-slide-menu-title">{{ slide_menu_title }}</h2>
        <button type="button" class="khalab-slide-menu-close" onclick="closeSlidingMenu()" aria-label="{{ _('Close') }}">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    <ul class="theme-text-for-primary-bg menu-header-theme-text-for-primary-bg khalab-slide-menu-list">
        {% for menu in store.settings.menus.main_menu.items %}
            {% if menu.url %}
            <li class="slide-menu-ul-li khalab-slide-menu-item {% if menu.slug == 'all_categories' %} all-categories {% endif %}" onclick="scrollToSubMenu(this)">
                <a href="{{ menu.url | localized_url if menu.resource_type != 'url' else menu.url }}" title="{{ menu.label }}" class="menu-link khalab-slide-menu-link">
                    <span class="khalab-slide-menu-link-text">{{ menu.label }}</span>
                </a>
                {% if menu.items | length > 0 %}
                    <ul>
                        {% for menu_sub in menu.items %}
                            <li class="slide-menu-ul-li khalab-slide-menu-item">
                                <a href="{{ menu_sub.url | localized_url if menu_sub.resource_type != 'url' else menu_sub.url }}" class="khalab-slide-menu-link">{{ menu_sub.label }}</a>
                                {% if menu_sub.items | length > 0 %}
                                    <ul>
                                        {% for menu_sub_sub in menu_sub.items %}
                                            <li class="slide-menu-ul-li khalab-slide-menu-item">
                                                <a href="{{ menu_sub_sub.url | localized_url if menu_sub_sub.resource_type != 'url' else menu_sub_sub.url }}" class="khalab-slide-menu-link">
                                                    {{ menu_sub_sub.label }}
                                                </a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </li>
            {% endif %}
        {% endfor %}
        <li class="slide-menu-ul-li khalab-slide-menu-item">
            <a href="/shipping-and-payment" class="khalab-slide-menu-link">
                <span class="khalab-slide-menu-link-text">{{ _("Payment and delivery options") }}</span>
            </a>
        </li>
    </ul>

    <div class="khalab-slide-menu-footer slide-menu-static">
        <div class="khalab-slide-menu-footer-inner account-lang-currency upper-bar">
            <div class="khalab-slide-menu-account">
                <button type="button" onclick="handleLoginAction(); closeSlidingMenu();" class="khalab-slide-menu-account-btn" id="login-btn-alt">
                    <span class="icon-account_circle_black_24dp" aria-hidden="true"></span>
                    <span>{{ _("Login") }}</span>
                </button>

                <button type="button" onclick="window.location.href='{{ url_for('profile') }}'" class="khalab-slide-menu-account-btn" id="hello-btn-alt" style="display: none;">
                   <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" color="#ffffff" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18.5 20V17.9704C18.5 16.7281 17.9407 15.5099 16.8103 14.9946C15.4315 14.3661 13.7779 14 12 14C10.2221 14 8.5685 14.3661 7.18968 14.9946C6.05927 15.5099 5.5 16.7281 5.5 17.9704V20"></path>
                        <circle cx="12" cy="7.5" r="3.5"></circle>
                    </svg>
                    <span id="customer-greeting-alt">{{ _("Hello") }} ...</span>
                </button>
            </div>

            {% set multiple_languages = store.languages | length > 1 %}
            {% set header_options_raw = safeget(settings, "header_options", []) %}
            {% set header_options =
                header_options_raw
                if header_options_raw is iterable and header_options_raw is not boolean and header_options_raw is not string
                else []
            %}

            {% set show_country = 'hide_country' not in header_options %}
            {% set show_language = 'hide_language' not in header_options %}

            {% if show_country or (multiple_languages and show_language) %}
                <button type="button" class="khalab-slide-menu-region-btn language-currency language-currency-menu" onclick="zidOpenRegionSettingDialog()">
                    {% if session.lang == 'en' %}
                        {% set change_to_lang_name = 'العربية' %}
                    {% else %}
                        {% set change_to_lang_name = 'English' %}
                    {% endif %}

                    {% if show_country %}
                        {% if session.shipping_destination %}
                            <span class="khalab-slide-menu-region-label">{{ session.shipping_destination.country.name }}</span>
                        {% else %}
                            <span class="khalab-slide-menu-region-label">{{ session.country.names[session.lang] }}</span>
                        {% endif %}
                    {% endif %}

                    {% if show_country and (multiple_languages and show_language) %}
                        <span class="khalab-slide-menu-region-divider" aria-hidden="true"></span>
                    {% endif %}

                    {% if multiple_languages and show_language %}
                        <span class="khalab-slide-menu-lang-label">{{ change_to_lang_name }}</span>
                        <span class="icon-language_white icon-language_white-menu" aria-hidden="true"></span>
                    {% endif %}
                </button>
            {% endif %}
        </div>
    </div>
</nav>

<script>
document.addEventListener('zid-customer-fetched', function (event) {
    const customer = event.detail.customer;
    if (customer && customer.name) {
        const greeting = document.getElementById('customer-greeting-alt');
        if (!greeting) return;

        const greetingText = greeting.textContent.trim();
        const helloWord = greetingText.split(' ')[0];
        greeting.textContent = helloWord + ' ' + customer.name;

        const helloBtn = document.getElementById('hello-btn-alt');
        const loginBtn = document.getElementById('login-btn-alt');
        if (helloBtn) helloBtn.style.display = 'inline-flex';
        if (loginBtn) loginBtn.style.display = 'none';
    }
});
</script>
