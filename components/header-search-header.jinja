{% if settings.header_logo_home %}
    {% set homeLogo = settings.header_logo_home %}
{% endif %}

{% if settings.header_logo %}
    {% set logoUrl = settings.header_logo %}
{% else %}
    {% set logoUrl = store.logo %}
{% endif %}

{% if settings.header_logo_mobile %}
    {% set logoUrlMobile = settings.header_logo_mobile %}
{% elif store.settings.branding.mobile_app_logo %}
    {% set logoUrlMobile = store.settings.branding.mobile_app_logo %}
{% else %}
    {% set logoUrlMobile = logoUrl %}
{% endif %}

<div class="search-header header-theme-bg-primary khalab-header">
    <div class="container-fluid khalab-header-container">
        {# ── Desktop header ── #}
        <div class="khalab-header-bar khalab-header-bar--desktop d-none d-lg-flex">
            <div class="khalab-header-logo">
                <a href="/" class="khalab-logo-link">
                    <img class="image-logo khalab-logo khalab-logo-default{% if logoUrlMobile is defined and logoUrlMobile is not none and (settings.header_logo_mobile or store.settings.branding.mobile_app_logo) %} d-none d-lg-block{% endif %}"
                         src="{{ image_url(logoUrl, h=175, q=100) }}"
                         alt="{{ store.name }}"
                         decoding="async"
                         fetchpriority="high">

                    {% if homeLogo is defined and homeLogo is not none %}
                        <img class="image-logo khalab-logo khalab-logo-home"
                             src="{{ image_url(homeLogo, h=175, q=100) }}"
                             alt="{{ store.name }}"
                             decoding="async"
                             fetchpriority="high">
                    {% endif %}
                </a>
            </div>

            <nav class="khalab-nav-pill" aria-label="{{ _('Main navigation') }}">
