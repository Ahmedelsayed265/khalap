                            </svg>
                        </button>
                    </div>

                    <div class="khalab-nav-pill-group khalab-nav-links d-none d-lg-flex">
                        {% include 'components/header-khalab-nav-menu.jinja' %}
                    </div>

                    <a href="{{ settings.header_buy_now_url or '/products' }}" class="khalab-nav-cta">
                        {{ settings.header_buy_now_text or 'أشتري الآن' }}
                    </a>
