{% if product %}

{% set preorder_badge_variant = 'default' %}
{% set selected_product = product.selected_product %}
{% set has_preorder = product.effective_preorder_campaign is not none %}
{% set can_preorder = product.can_be_preordered %}
{% set is_in_stock_or_preorderable = product.is_infinite or product.quantity > 0 or can_preorder %}
{% set is_out_of_stock = (product.is_infinite == false and product.quantity <= 0) and not can_preorder %}
{% set card_vector = 'image 126.png' | asset_url %}
{% set product_image = '' %}
{% if product.images or product.videos %}
    {% if product.main_image %}
        {% set product_image = product.main_image.image.medium %}
    {% else %}
        {% set product_image = image_url(('product-img.svg' | asset_url), w=470, q=90, f='auto') %}
    {% endif %}
{% else %}
    {% set product_image = image_url(('product-img.svg' | asset_url), w=470, q=90, f='auto') %}
{% endif %}

<article class="product-item khalab-product-card{% if is_out_of_stock %} product-item-out-of-stock{% endif %}">
    <div class="khalab-product-card-inner">
        <div class="khalab-product-card-top">
            <div class="khalab-product-card-media">
                <a href="/products/{{ product.slug }}" class="khalab-product-card-media-link" tabindex="-1" aria-hidden="true">
                    {% if product.badge %}
                        {% set positionProductCard = true %}
                        {% include 'vitrin:products/badge.jinja' %}
                    {% endif %}
                    <img
                        id="product-card-img-{{ product.id }}"
                        src="{{ product_image }}"
                        alt="{{ product.name }}"
                        class="khalab-product-card-photo"
                        loading="lazy"
                        draggable="false"
                    >
                    <span class="product-card-bundle-offer" data-bundle-offer-product-id="{{ product.id }}"></span>
                </a>
            </div>

            <div class="khalab-product-card-actions">
                <a href="/products/{{ product.slug }}" class="khalab-product-card-action khalab-product-card-action--view" aria-label="{{ _('View product') }}">
                    <svg class="khalab-product-card-action-icon" viewBox="0 0 41 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M1.75 14C9.1 -2.33332 31.15 -2.33332 38.5 14" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M17.7811 21.7838C18.5242 22.0916 19.3207 22.25 20.125 22.25C21.7495 22.25 23.3074 21.6047 24.456 20.456C25.6047 19.3074 26.25 17.7495 26.25 16.125C26.25 14.5006 25.6047 12.9426 24.456 11.794C23.3074 10.6453 21.7495 10 20.125 10C19.3207 10 18.5242 10.1584 17.7811 10.4662C17.0379 10.7741 16.3627 11.2252 15.794 11.794C15.2252 12.3627 14.774 13.038 14.4662 13.7811C14.1584 14.5242 14 15.3207 14 16.125C14 16.9294 14.1584 17.7258 14.4662 18.4689C14.774 19.2121 15.2252 19.8873 15.794 20.456C16.3627 21.0248 17.0379 21.476 17.7811 21.7838Z" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>

                {% if store.settings.products.wishlist_enabled == true %}
                    <span class="khalab-product-card-action khalab-product-card-action--wishlist add-to-wishlist" data-wishlist-id="{{ product.id }}">
                        <button type="button" zid-visible-customer="true" class="khalab-product-card-wishlist-btn" onclick="event.preventDefault(); event.stopPropagation(); addToWishlist(this, '{{ product.id }}')" aria-label="{{ _('Add to wishlist') }}">
                            {% set icon_class = 'khalab-product-card-action-icon' %}{% include 'components/khalab-wishlist-icon.jinja' %}
                        </button>
                        <a zid-visible-guest="true" class="khalab-product-card-wishlist-btn" href="/auth/login?redirect_to={{ session.url.path }}" onclick="event.preventDefault(); event.stopPropagation(); handleLoginAction('', false); return false;" aria-label="{{ _('Add to wishlist') }}">
                            {% set icon_class = 'khalab-product-card-action-icon' %}{% include 'components/khalab-wishlist-icon.jinja' %}
                        </a>
                        {% set loader_size = 'sm' %}{% set loader_class = 'loader d-none' %}{% include 'components/khalab-loader.jinja' %}
                    </span>
                {% else %}
                    <span class="khalab-product-card-action khalab-product-card-action--wishlist khalab-product-card-action--placeholder" aria-hidden="true"></span>
                {% endif %}
            </div>
        </div>

        <div class="khalab-product-card-bottom">
            <img src="{{ card_vector }}" alt="" class="khalab-product-card-vector" loading="lazy" draggable="false">
            <div class="khalab-product-card-info">
                {% if has_preorder %}
                    <div class="khalab-product-card-preorder">
                        {% set preorder_badge_variant = 'product_card' %}
                        {% include 'vitrin:products/preorder_badge.jinja' %}
                    </div>
                {% endif %}

                <h3 class="khalab-product-card-title">
                    <a href="/products/{{ product.slug }}">{{ product.name | safe }}</a>
                </h3>

                {% if is_in_stock_or_preorderable and (product.has_options or product.has_fields) %}
                    <p class="khalab-product-card-subtitle">{{ _("Available in several options") }}</p>
                {% elif is_out_of_stock %}
                    <p class="khalab-product-card-subtitle">{{ _("This product is out of stock") }}</p>
                {% elif not product.is_taxable %}
                    <p class="khalab-product-card-subtitle">{{ _("Tax free") }}</p>
                {% endif %}

                {% if store.settings.products.reviews_enabled and product.rating %}
                    <div class="khalab-product-card-rating product-card-rating-wrapper">
                        {% set rating=product.rating.average %}{% include 'components/rating-stars.jinja' %}
                        {% if product.rating.total_count > 0 %}
                            <span class="product-card-rating-count">({{ product.rating.total_count }})</span>
                        {% endif %}
                    </div>
                {% endif %}

                <div class="khalab-product-card-prices">
                    {% if product.formatted_sale_price is not none %}
                        <span class="khalab-product-card-price">{{ product.formatted_sale_price }}</span>
                        <span class="khalab-product-card-compare">{{ product.formatted_price }}</span>
                    {% else %}
                        <span class="khalab-product-card-price">{{ product.formatted_price }}</span>
                    {% endif %}
                </div>

                <div class="khalab-product-card-cta-wrap">
                    {% if is_out_of_stock %}
                        <a href="/products/{{ product.slug }}" class="khalab-product-card-cta">
                            <img src="{{ 'u_bell.svg' | asset_url }}" alt="" width="18" height="18">
                            <span>{{ _("Notify me when available") }}</span>
                        </a>
                    {% elif product.has_options or product.has_fields or product.product_class == 'dynamic_bundle' %}
                        <a href="/products/{{ product.slug }}" class="khalab-product-card-cta">
                            <img src="{{ 'buy-now.svg' | asset_url }}" alt="" width="18" height="18">
                            <span>{{ _("Preorder now") if has_preorder else _("add to cart") }}</span>
                        </a>
                    {% else %}
                        <button type="button" class="khalab-product-card-cta product-card-add-to-cart" onclick="productCartAddToCart(this,'{{ product.id }}')">
                            {% set loader_size = 'sm' %}{% set loader_class = 'add-to-cart-progress d-none' %}{% include 'components/khalab-loader.jinja' %}
                            <img src="{{ 'buy-now.svg' | asset_url }}" alt="" width="20" height="20" class="khalab-product-card-cta-icon">
                            <span>{{ _("Buy now") if not has_preorder else _("Preorder now") }}</span>
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</article>
{% endif %}
