{% set default_service_links = [
    {'title': 'تواصل معنا', 'url': '/contact-us'},
    {'title': 'الشحن والتوصيل', 'url': '/shipping-and-payment'},
    {'title': 'سياسة الإرجاع', 'url': '/return-policy'},
    {'title': 'الأسئلة الشائعة', 'url': '/faqs'}
] %}
{% set default_useful_links = [
    {'title': 'من نحن', 'url': '/about-us'},
    {'title': 'المنتجات', 'url': '/products'},
    {'title': 'تخصيص لوحة', 'url': '/products'},
    {'title': 'المدونة', 'url': '/blogs'}
] %}

{% set brand_headline = settings.brand_headline or 'لأن كل مكان يستحق لوحة تليق به' %}
{% set brand_description = settings.brand_description or 'صنعنا خلاب عشان نجيبلك الفن اللي مش بس يزين الجدار، لكن يضيف روح للمكان كله ويخلي كل زاير يحس بالفرق من أول نظرة.' %}
{% set cta_primary_text = settings.brand_cta_primary_text or 'اشترك الآن' %}
{% set cta_primary_url = settings.brand_cta_primary_url or '/newsletter' %}
{% set cta_secondary_text = settings.brand_cta_secondary_text or 'تخصيص لوحة' %}
{% set cta_secondary_url = settings.brand_cta_secondary_url or '/products' %}
{% set logo_en = settings.brand_logo_en or 'KHALLAB' %}

{% set service_links = settings.links_1_links if settings.links_1_links | length > 0 else default_service_links %}
{% set useful_links = settings.links_2_links if settings.links_2_links | length > 0 else default_useful_links %}

{% set copyright_text = settings.legal_copyright or store.settings.branding.copyrights or 'جميع الحقوق محفوظة - خلاب 2025 ©' %}
{% set privacy_label = settings.legal_privacy_label or 'سياسة الخصوصية' %}
{% set privacy_url = settings.legal_privacy_url or '/privacy-policy' %}
{% set footer_phone = settings.social_phone or store.settings.contact.phone %}
{% set footer_email = settings.social_email or store.settings.contact.email %}

<div class="khalab-footer" style="--khalab-footer-grid: url('{{ 'grid_patern.svg' | asset_url }}');">
    <div class="khalab-footer-bg" aria-hidden="true">
        <img
            src="{{ settings.brand_background_image or ('bg.png' | asset_url) }}"
            alt=""
            class="khalab-footer-bg-texture"
            loading="lazy"
        >
    </div>

    <div class="khalab-footer-brand">
        <div class="khalab-footer-brand-inner">
            <div class="khalab-footer-logo-wrap">
                <img
                    src="{{ settings.brand_logo or ('khalap.png' | asset_url) }}"
                    alt="خلاب"
                    class="khalab-footer-logo-wordmark"
                    width="120"
                    height="48"
                    loading="lazy"
                >
            </div>

            <h2 class="khalab-footer-headline">{{ brand_headline }}</h2>

            {% if brand_description %}
                <p class="khalab-footer-description">{{ brand_description | safe }}</p>
            {% endif %}

            <div class="khalab-footer-cta-row">
                <a href="{{ cta_primary_url }}" class="khalab-footer-btn">
                    <span class="khalab-footer-btn-text">{{ cta_primary_text }}</span>
                    <span class="khalab-footer-btn-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12H19M12 5L19 12L12 19"/>
                        </svg>
                    </span>
                </a>
                <a href="{{ cta_secondary_url }}" class="khalab-footer-btn">
                    <span class="khalab-footer-btn-text">{{ cta_secondary_text }}</span>
                    <span class="khalab-footer-btn-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12H19M12 5L19 12L12 19"/>
                        </svg>
                    </span>
                </a>
            </div>
        </div>
    </div>

    <div class="khalab-footer-links">
        <div class="khalab-footer-links-inner">
            <div class="khalab-footer-columns">
                {% if not settings.links_1_hide %}
                    <div class="khalab-footer-col khalab-footer-col--service">
                        <h3 class="khalab-footer-col-title">{{ settings.links_1_title or 'خدمة العملاء' }}</h3>
                        <ul class="khalab-footer-pill-list">
                            {% for link in service_links %}
                                {% set link_url = link.url %}
                                {% if link_url is mapping %}
                                    {% set link_url = link_url.url | default(link_url.href | default('#')) %}
                                {% endif %}
                                <li class="khalab-footer-service-item">
                                    <a href="{{ link_url or '#' }}" class="khalab-footer-pill">
                                        <span>{{ link.title }}</span>
                                    </a>

                                    <span class="khalab-footer-link-arrow" aria-hidden="true">
                                        <div class="khalab-footer-link-arrow-icon">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M12 3.97C16.41 3.97 20.03 7.59 20.03 12C20.03 16.41 16.41 20.03 12 20.03C7.59 20.03 3.97 16.41 3.97 12C3.97 7.59 7.59 3.97 12 3.97ZM12 2C6.46 2 2 6.46 2 12C2 17.54 6.46 22 12 22C17.54 22 22 17.54 22 12C22 6.46 17.54 2 12 2ZM10.12 11.53L8 13.64L8 8L13.64 8L11.53 10.12L16.5 15.1L15.1 16.5" fill="#323824"/>
                                            </svg>
                                        </div>
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if not settings.links_2_hide %}
                    <div class="khalab-footer-col khalab-footer-col--links">
                        <h3 class="khalab-footer-col-title">{{ settings.links_2_title or 'روابط تهمك' }}</h3>
                        <ul class="khalab-footer-text-list">
                            {% for link in useful_links %}
                                {% set link_url = link.url %}
                                {% if link_url is mapping %}
                                    {% set link_url = link_url.url | default(link_url.href | default('#')) %}
                                {% endif %}
                                <li>
                                    <a href="{{ link_url or '#' }}" class="khalab-footer-text-link">
                                        <span>{{ link.title }}</span>
                                     
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M12 3.97C16.41 3.97 20.03 7.59 20.03 12C20.03 16.41 16.41 20.03 12 20.03C7.59 20.03 3.97 16.41 3.97 12C3.97 7.59 7.59 3.97 12 3.97ZM12 2C6.46 2 2 6.46 2 12C2 17.54 6.46 22 12 22C17.54 22 22 17.54 22 12C22 6.46 17.54 2 12 2ZM10.12 11.53L8 13.64L8 8L13.64 8L11.53 10.12L16.5 15.1L15.1 16.5" fill="#323824"/>
                                        </svg>
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {% if not settings.social_hide %}
                    <div class="khalab-footer-col khalab-footer-col--social">
