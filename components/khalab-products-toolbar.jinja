{% if session.lang == 'ar' %}
  {% set pl_sort_label = 'ترتيب حسب' %}
  {% set pl_page_label = 'الصفحة' %}
  {% set pl_search_label = 'بحث فوري' %}
  {% set pl_filter_label = 'فلتر النتائج' %}
  {% set pl_sort_default = 'الإفتراضي' %}
{% else %}
  {% set pl_sort_label = _('Sort by') %}
  {% set pl_page_label = _('Page') %}
  {% set pl_search_label = _('Instant search') %}
  {% set pl_filter_label = _('Filter results') %}
  {% set pl_sort_default = _('Default') %}
{% endif %}

{% if session.query_params.get('sort_by') == 'popularity_order' %}
  {% set pl_sort_current = _("Most popular") %}
{% elif session.query_params.get('sort_by') == 'price' and session.query_params.get('order') == 'asc' %}
  {% set pl_sort_current = _("Low to high") %}
{% elif session.query_params.get('sort_by') == 'price' and session.query_params.get('order') == 'desc' %}
  {% set pl_sort_current = _("High to low") %}
{% else %}
  {% set pl_sort_current = pl_sort_default %}
{% endif %}

{% set page_num = currentPage | default(1) %}
{% set pages_total = totalPages | default(1) %}

<div class="khalab-pl-toolbar products-filter">
  <div class="khalab-pl-toolbar-group khalab-pl-toolbar-group--actions">
    <div class="khalab-pl-toolbar-split" role="group" aria-label="{{ pl_filter_label }}">
      <button
        type="button"
        class="khalab-pl-toolbar-split-btn khalab-pl-toolbar-split-btn--filter d-lg-none"
        data-bs-toggle="collapse"
        data-bs-target="#filters-form-collapse-sm"
        aria-expanded="false"
        aria-controls="filters-form-collapse-sm"
        aria-label="{{ pl_filter_label }}"
      >
        <svg class="khalab-pl-toolbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 5H20M7 12H17M10 19H14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <circle cx="18" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="6" cy="12" r="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="15" cy="19" r="2" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span>{{ pl_filter_label }}</span>
      </button>

      <button
        type="button"
        class="khalab-pl-toolbar-split-btn khalab-pl-toolbar-split-btn--filter d-none d-lg-inline-flex"
        data-bs-toggle="modal"
        data-bs-target="#filterModal"
        aria-label="{{ pl_filter_label }}"
      >
        <svg class="khalab-pl-toolbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 5H20M7 12H17M10 19H14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <circle cx="18" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="6" cy="12" r="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="15" cy="19" r="2" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span>{{ pl_filter_label }}</span>
      </button>

      <span class="khalab-pl-toolbar-split-divider" aria-hidden="true"></span>

      <button type="button" class="khalab-pl-toolbar-split-btn khalab-pl-toolbar-split-btn--search" data-khalab-open-search aria-label="{{ pl_search_label }}">
        <svg class="khalab-pl-toolbar-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.8"/>
          <path d="M16 16L20 20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M7 11H15M11 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>{{ pl_search_label }}</span>
      </button>
    </div>
  </div>

  <div class="khalab-pl-toolbar-group khalab-pl-toolbar-group--meta">
    <div class="dropdown khalab-pl-pill khalab-pl-pill--page">
      <button type="button" class="khalab-pl-pill-toggle" data-khalab-dropdown-toggle aria-expanded="false">
        <span class="khalab-pl-pill-label">{{ pl_page_label }}</span>
        <span class="khalab-pl-pill-value">
          <span class="khalab-pl-pill-value-text">{{ page_num }}</span>
          <svg class="khalab-pl-pill-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>
      <ul class="dropdown-menu khalab-pl-dropdown select-dropdown">
        {% for n in range(1, pages_total + 1) %}
          <li>
            <a class="dropdown-item{% if page_num == n %} active{% endif %}" {% if page_num != n %}href="{{ session.url.include_query_params(page=n) }}"{% endif %}>{{ n }}</a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="dropdown khalab-pl-pill khalab-pl-pill--sort">
      <button
        id="products-list-sort"
        type="button"
        class="khalab-pl-pill-toggle"
        data-khalab-dropdown-toggle
        aria-expanded="false"
      >
        <span class="khalab-pl-pill-label">{{ pl_sort_label }}</span>
        <span class="khalab-pl-pill-value">
          <span class="khalab-pl-pill-value-text">{{ pl_sort_current }}</span>
          <svg class="khalab-pl-pill-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>
      <ul class="dropdown-menu khalab-pl-dropdown select-dropdown">
        <li><a class="dropdown-item" href="{{ session.url.include_query_params(sort_by='created_at', order='desc') }}">{{ pl_sort_default }}</a></li>
        <li><a class="dropdown-item" href="{{ session.url.include_query_params(sort_by='popularity_order', order='asc') }}">{{ _("Most popular") }}</a></li>
        <li><a class="dropdown-item" href="{{ session.url.include_query_params(sort_by='price', order='asc') }}">{{ _("Low to high") }}</a></li>
        <li><a class="dropdown-item" href="{{ session.url.include_query_params(sort_by='price', order='desc') }}">{{ _("High to low") }}</a></li>
      </ul>
    </div>
  </div>
</div>
