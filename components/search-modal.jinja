<div id="search-modal" class="khalab-search-modal" aria-hidden="true" data-no-results="{% if session.lang == 'ar' %}لا توجد نتائج{% else %}{{ _('No results found') | e }}{% endif %}">
    <div class="khalab-search-modal-backdrop" onclick="closeSearchModal()"></div>

    <div class="khalab-search-modal-panel" role="dialog" aria-modal="true" aria-labelledby="khalab-search-title">
        <div class="khalab-search-modal-head">
            <h2 id="khalab-search-title" class="khalab-search-modal-title">{% if session.lang == 'ar' %}عن ماذا تبحث؟{% else %}{{ _('What are you looking for?') }}{% endif %}</h2>
            <button type="button" class="khalab-search-modal-close" onclick="closeSearchModal()" aria-label="{{ _('Close') }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <path d="M18 6L6 18M6 6L18 18"/>
                </svg>
            </button>
        </div>

        <div class="khalab-search-modal-autocomplete">
            <form class="khalab-search-modal-form" onsubmit="return submitKhalabSearch(event)">
                <span class="khalab-search-modal-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 17L21 21"/>
                        <path d="M19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19C15.4183 19 19 15.4183 19 11Z"/>
                    </svg>
                </span>
                <input type="text"
                       id="khalab-search-input"
                       class="khalab-search-modal-input search-input-input"
                       placeholder="{% if settings.header_search_placeholder %}{{ settings.header_search_placeholder }}{% else %}{{ _('Search') }}{% endif %}"
                       autocomplete="off"
                       spellcheck="false">
            </form>

            <div class="khalab-search-modal-results autocomplete-items" aria-live="polite"></div>
        </div>
    </div>
</div>
