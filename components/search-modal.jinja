<div id="search-modal" class="khalab-search-modal">
    <div class="khalab-search-modal-backdrop" onclick="closeSearchModal()"></div>
    <div class="khalab-search-modal-panel">
        <button type="button" class="khalab-search-modal-close" onclick="closeSearchModal()" aria-label="{{ _('Close') }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M18 6L6 18M6 6L18 18"/>
            </svg>
        </button>

        <form class="khalab-search-modal-form" onsubmit="return submitKhalabSearch(event)">
            <span class="khalab-search-modal-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 17L21 21"/>
                    <path d="M19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19C15.4183 19 19 15.4183 19 11Z"/>
                </svg>
            </span>
            <input type="text"
                   id="khalab-search-input"
                   class="khalab-search-modal-input"
                   placeholder="{% if settings.header_search_placeholder %}{{ settings.header_search_placeholder }}{% else %}{{ _('Search') }}{% endif %}"
                   autocomplete="off">
        </form>
    </div>
</div>
