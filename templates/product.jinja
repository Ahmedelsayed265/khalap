{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
    <link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ 'ekko-lightbox.css' | asset_url }}" />

    <link rel="stylesheet" type="text/css" href="{{ ('product-details.css?v=' ~ ver)  | asset_url }}" />

{% endblock %}


{% block main_content %}

    {% if product %}
        {% set selected_product = selected_product if selected_product is defined else product.selected_product %}
        {% set has_preorder = product.effective_preorder_campaign is not none %}
        {% set can_preorder = product.can_be_preordered %}
        {% set preorder_stock_behavior = product.preorder_stock_behavior %}
        {% set can_buy = (selected_product and (selected_product.in_stock or can_preorder)) %}
    {% else %}
        {% set has_preorder = false %}
        {% set can_preorder = false %}
        {% set preorder_stock_behavior = '' %}
        {% set can_buy = false %}
    {% endif %}

    <section class="product products-details-page"
             data-has-preorder="{{ 'true' if has_preorder else 'false' }}"
             data-can-preorder="{{ 'true' if can_preorder else 'false' }}"
             data-stock-behavior="{{ preorder_stock_behavior or '' }}">
        <div class="container pb-5">
            <section class="products-details mb-5 khalab-pdp">
                <div class="khalab-pdp-layout">
                    <div class="khalab-pdp-gallery-col">
                        {% include 'components/khalab-product-gallery.jinja' %}
                    </div>

                    <div class="khalab-pdp-info-col col-product-info {% if product.selected_product.media | length <= 1 %}col-product-info-single-image{% endif %}">

                            {% if session.lang == 'ar' %}
                                {% set khalab_lbl_price = 'السعر' %}
                                {% set khalab_lbl_sku = 'رمز المنتج' %}
                                {% set khalab_lbl_payment = 'خيارات الدفع' %}
                                {% set khalab_lbl_categories = 'التصنيفات' %}
                                {% set khalab_lbl_weight = 'الوزن' %}
                                {% set khalab_lbl_tags = 'الوسوم' %}
                            {% else %}
                                {% set khalab_lbl_price = _('price') %}
                                {% set khalab_lbl_sku = _('product sku') %}
                                {% set khalab_lbl_payment = _('Payment Options') %}
                                {% set khalab_lbl_categories = _('Categories') %}
                                {% set khalab_lbl_weight = _('Weight') %}
                                {% set khalab_lbl_tags = _('Tags') %}
                            {% endif %}

                            <div class="khalab-pdp-header-glass">
                                <div class="khalab-pdp-header-copy">
                                    {% if product.badge %}
                                       {% include 'vitrin:products/badge.jinja' %}
                                    {% endif %}
                                    {% if product.preorder_campaign %}
                                        {% include 'vitrin:products/preorder_badge.jinja' %}
                                    {% endif %}
                                    <h1 class="khalab-pdp-title">{{ product.name | safe }}</h1>
                                    {% if product.short_description %}
                                        <p class="khalab-pdp-subtitle">
                                            {{ product.short_description | striptags }}
                                            <a id="product-description-a" href="#product-description" class="khalab-pdp-read-more">{{ _("more information") }}</a>
                                        </p>
                                    {% endif %}
                                </div>
                                <div class="khalab-pdp-header-actions">
                                    {% if store.settings.products.wishlist_enabled == true %}
                                        <span class="khalab-pdp-action-btn add-to-wishlist" data-wishlist-id="{{ product.id }}">
                                            <span class="khalab-wishlist-toggle" zid-visible-customer="true">
                                                <button type="button" zid-visible-wishlist="{{ product.id }}" class="khalab-wishlist-btn" onclick="addToWishlist(this, '{{ product.id }}')" aria-label="{{ _('Remove from wishlist') }}">
                                                    <img src="{{ 'save-filled.svg' | asset_url }}" alt="" width="20" height="20">
                                                </button>
                                                <button type="button" zid-hidden-wishlist="{{ product.id }}" class="khalab-wishlist-btn" onclick="addToWishlist(this, '{{ product.id }}')" aria-label="{{ _('Add to wishlist') }}">
                                                    <img src="{{ 'save.svg' | asset_url }}" alt="" width="20" height="20">
                                                </button>
                                            </span>
                                            <a zid-visible-guest="true" class="khalab-wishlist-btn" href="{{ url_for('login_page', query_params={'redirect_to': session.path}) }}" onclick="event.preventDefault(); handleLoginAction('{{ session.path }}'); return false;" aria-label="{{ _('Add to wishlist') }}">
                                                <img src="{{ 'save.svg' | asset_url }}" alt="" width="20" height="20">
                                            </a>
                                            {% set loader_size = 'sm' %}{% set loader_class = 'loader d-none' %}{% include 'components/khalab-loader.jinja' %}
                                        </span>
                                    {% endif %}
                                    <button type="button" class="khalab-pdp-action-btn share-btn" data-khalab-share-toggle aria-expanded="false" aria-label="{{ _('share product') }}">
                                        <svg width="16" height="16" viewBox="0 0 32 32" aria-hidden="true"><path fill="currentColor" d="M26.667 21.333c-1.699 0-3.196 0.812-4.173 2.052l-11.912-5.211c0.044-0.276 0.085-0.553 0.085-0.841 0-0.472-0.081-0.923-0.197-1.359l12.361-6.952c0.971 1.009 2.328 1.644 3.836 1.644 2.941 0 5.333-2.392 5.333-5.333s-2.392-5.333-5.333-5.333-5.333 2.392-5.333 5.333c0 0.472 0.081 0.923 0.197 1.359l-12.361 6.952c-0.971-1.009-2.328-1.644-3.836-1.644-2.941 0-5.333 2.392-5.333 5.333s2.392 5.333 5.333 5.333c1.699 0 3.196-0.812 4.173-2.052l11.912 5.211c-0.044 0.276-0.085 0.553-0.085 0.841 0 2.941 2.392 5.333 5.333 5.333s5.333-2.392 5.333-5.333-2.392-5.333-5.333-5.333z"></path></svg>
                                    </button>
                                </div>
                                <div class="khalab-pdp-share-panel d-none" data-khalab-share-panel>
                                    <div class="khalab-pdp-share-links">
                                        <a href="https://www.facebook.com/sharer/sharer.php?u={{ product.html_url }}" target="_blank" rel="noopener" aria-label="Facebook"><i class="icon-facebook-f"></i></a>
                                        <a href="https://twitter.com/intent/tweet?text={{ product.name }}: {{ product.html_url }}" target="_blank" rel="noopener" aria-label="X"><i class="icon-twitter"></i></a>
                                        <a href="https://api.whatsapp.com/send?text={{ _("Check Out this Product") }} :{{ product.name }} {{ product.html_url }}" target="_blank" rel="noopener" aria-label="WhatsApp"><i class="icon-whatsapp"></i></a>
                                        <a href="https://www.pinterest.com/pin/create/button/?url={{ product.html_url }}" target="_blank" rel="noopener" aria-label="Pinterest"><i class="icon-pinterest"></i></a>
                                    </div>
                                </div>
                            </div>

                            <div class="khalab-pdp-details-glass">
                                <div class="khalab-pdp-row-item">
                                    <span class="khalab-pdp-row-label">{{ khalab_lbl_price }}</span>
                                    <div class="khalab-pdp-row-value">
                                        <div class="khalab-pdp-price-pill">
                                            <h2 class="product-formatted-price khalab-pdp-price theme-text-primary">{% if product.selected_product.formatted_sale_price %}{{ product.selected_product.formatted_sale_price }}{% else %}{{ product.selected_product.formatted_price }}{% endif %}</h2>
                                            <del class="product-formatted-price-old khalab-pdp-price-old">{% if product.selected_product.formatted_sale_price %}{{ product.selected_product.formatted_price }}{% endif %}</del>
                                            <span class="product-formatted-price-discount khalab-pdp-price-discount">{% if product.selected_product.formatted_sale_price %}{{ _("Discount") }} {{ product.discount_percentage }}%{% endif %}</span>
                                        </div>
                                        <div class="khalab-pdp-loyalty">
                                            {% include 'vitrin:products/loyalty_points_widget.jinja' %}
                                        </div>
                                    </div>
                                </div>

                                <div class="khalab-pdp-row-item div-product-sku {% if not product.selected_product.sku %}d-none{% endif %}">
                                    <span class="khalab-pdp-row-label">{{ khalab_lbl_sku }}</span>
                                    <div class="khalab-pdp-row-value">
                                        <div class="khalab-pdp-sku-pill">
                                            <button type="button" class="khalab-pdp-sku-copy" data-khalab-copy-sku aria-label="{{ _('Copy') }}">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                            </button>
                                            <span class="product-sku khalab-pdp-sku-text">{{ product.selected_product.sku }}</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="khalab-pdp-row-item div-product-weight {% if not product.selected_product.weight.value %}d-none{% endif %}">
                                    <span class="khalab-pdp-row-label">{{ khalab_lbl_weight }}</span>
                                    <div class="khalab-pdp-row-value">
                                        <div class="khalab-pdp-meta-pill product-weight">
                                            {{ product.selected_product.weight.value }}&nbsp;{{ product.selected_product.weight.unit }}
                                        </div>
                                    </div>
                                </div>

                                <div class="khalab-pdp-row-item">
                                    <span class="khalab-pdp-row-label">{{ khalab_lbl_payment }}</span>
                                    <div class="khalab-pdp-row-value">
                                        <div class="khalab-pdp-payment-pill">
                                            {% include 'vitrin:products/payment_widgets.jinja' %}
                                        </div>
                                    </div>
                                </div>

                                {% if product.categories and product.categories | length > 0 %}
                                <div class="khalab-pdp-row-item">
                                    <span class="khalab-pdp-row-label">{{ khalab_lbl_categories }}</span>
                                    <div class="khalab-pdp-row-value">
                                        <div class="khalab-pdp-tags-pill">
                                            {% for cat in product.categories %}
                                                {% set cat_url = (cat.url | default('', true)) | trim or url_for('category_details', category_id=cat.id, slug=cat.slug or cat.id) %}
                                                <a href="{{ cat_url }}" class="khalab-pdp-tag">{{ cat.name }}</a>{% if not loop.last %}<span class="khalab-pdp-tag-sep" aria-hidden="true">•</span>{% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                                {% endif %}

                                {% if product.keywords and product.keywords | length > 0 %}
                                <div class="khalab-pdp-row-item">
                                    <span class="khalab-pdp-row-label">{{ khalab_lbl_tags }}</span>
                                    <div class="khalab-pdp-row-value">
                                        <div class="khalab-pdp-tags-pill">
                                            {% for kw in product.keywords %}
                                                {% if kw.url is defined and kw.url %}
                                                    <a class="khalab-pdp-tag" href="{{ kw.url }}">#{{ kw.name | default(kw, true) }}</a>
                                                {% else %}
                                                    <a class="khalab-pdp-tag" href="/products?search={{ kw | urlencode }}">#{{ kw }}</a>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                                {% endif %}

                                <div class="khalab-pdp-preorder-wrap">
                                    {% include 'vitrin:products/preorder_countdown.jinja' %}
                                </div>

                                <div class="product-buttons khalab-pdp-actions {% if can_preorder or product.selected_product.in_stock %}d-block{% else %}d-none{% endif %}">
                                    <div class="khalab-pdp-action-row">
                                        <button class="khalab-pdp-btn khalab-pdp-btn--cart btn-add-to-cart" type="button" onclick="productAddToCart()">
                                            <span class="khalab-pdp-btn-icon" aria-hidden="true">
                                               <svg width="42" height="42" viewBox="0 0 82 82" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M47.8331 17.0833C47.8331 15.271 47.1132 13.5329 45.8317 12.2514C44.5502 10.9699 42.8121 10.25 40.9998 10.25C39.1875 10.25 37.4494 10.9699 36.1679 12.2514C34.8864 13.5329 34.1664 15.271 34.1664 17.0833M65.8048 33.128L70.5369 63.878C70.6865 64.8512 70.6241 65.8453 70.3538 66.7922C70.0836 67.7391 69.6119 68.6163 68.971 69.3639C68.3302 70.1115 67.5353 70.7118 66.6409 71.1236C65.7465 71.5355 64.7736 71.7491 63.789 71.75H18.2106C17.2254 71.7501 16.2517 71.5372 15.3565 71.1258C14.4612 70.7144 13.6655 70.1142 13.0239 69.3665C12.3823 68.6188 11.91 67.7412 11.6394 66.7938C11.3687 65.8465 11.3061 64.8518 11.4559 63.878L16.1879 33.128C16.4362 31.5139 17.2542 30.0421 18.4939 28.9792C19.7337 27.9162 21.3131 27.3323 22.9461 27.3333H59.0535C60.6859 27.3331 62.2645 27.9174 63.5035 28.9803C64.7425 30.0432 65.5567 31.5145 65.8048 33.128Z" stroke="#323824" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </span>
                                            {% set loader_size = 'lg' %}{% set loader_class = 'add-to-cart-progress d-none' %}{% include 'components/khalab-loader.jinja' %}
                                            <span class="khalab-pdp-btn-label">{% if product.preorder_campaign %}{{ _("Preorder now") }}{% else %}{{ _("add to cart") }}{% endif %}</span>
                                        </button>

                                        {% include 'vitrin:checkout/checkout_dialog.jinja' %}

                                        {% if not safeget(store, 'settings.general.availability.closed_now') and not product.preorder_campaign %}
                                        <button class="khalab-pdp-btn khalab-pdp-btn--buy btn-buy-now d-none" type="button" onclick="zidProductBuyNow()">
                                            <span class="khalab-pdp-btn-icon" aria-hidden="true">
                                                <svg width="42" height="42" viewBox="0 0 62 62" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <g clip-path="url(#clip0_2136_1441)">
                                                    <path d="M40.0415 42.6248H42.6248M45.2082 47.7915V60.7082H1.2915V24.5415H45.2082V37.4582" stroke="#323824" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                                                    <path d="M9.0415 24.5416V60.7082M10.9377 20.4237L17.8817 9.68481M11.8238 24.5416L9.0415 11.5836L54.5056 1.82373L59.928 27.0836L45.2082 30.243M56.4043 10.6639L45.6654 3.72248M58.0293 18.2434L51.0878 28.9797M47.7915 47.7916H36.1665L32.2915 42.6249L36.1665 37.4582H47.7915V47.7916Z" stroke="#323824" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                                                    <path d="M35.9261 13.7379L30.8731 14.8229L30.1523 17.6207L31.9581 19.8759L37.0111 18.7909L38.8143 21.0462L38.0935 23.8413L34.8359 24.5414M33.3996 14.2804L32.8571 11.7539" stroke="#323824" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </g>
                                                    <defs>
                                                    <clipPath id="clip0_2136_1441">
                                                    <rect width="62" height="62" fill="white"/>
                                                    </clipPath>
                                                    </defs>
                                                </svg>
                                            </span>
                                            {% set loader_size = 'lg' %}{% set loader_class = 'buy-now-progress d-none' %}{% include 'components/khalab-loader.jinja' %}
                                            <span class="khalab-pdp-btn-label">{{ _("Buy now") }}</span>
                                        </button>
                                        {% endif %}
                                    </div>

                                    <div class="khalab-pdp-apple-pay">
                                        {% include 'vitrin:checkout/apple-pay-quick-checkout.jinja' %}
                                    </div>
                                </div>
                            </div>

                            <form id="product-form">
                                <input id="product-id" type="hidden" value="{{ product.selected_product.id }}">

                                <div class="size-box khalab-pdp-variant-source">
                                    {% if product.has_variants or product.has_options %}
                                    <div class="khalab-variant-panel" data-select-label="{{ _('Select') | e }}">
                                        <script type="application/json" id="khalab-product-variant-data">{{ {
                                            'id': product.id,
                                            'options': product.options,
                                            'variants': product.variants,
                                            'selected_product': product.selected_product
                                        } | tojson }}</script>
                                        {% include 'vitrin:products/variants_list.jinja' %}
                                    </div>
                                    {% else %}
                                        {% include 'vitrin:products/variants_list.jinja' %}
                                    {% endif %}

                                    {% if product.custom_input_fields %}
                                        <div class="khalab-pdp-custom-fields">
                                            {% include 'vitrin:products/custom_input_fields.jinja' %}
                                        </div>
                                    {% endif %}
                                </div>

                                {% if product.selected_product.is_infinite or product.selected_product.quantity > 0 %}
                                    <div class="select-quantity-div khalab-pdp-qty d-none">
                                        <h4 class="product-title">{{ _("Quantity") }}</h4>
                                        <div class="form-group">
                                            <select id="product-quantity" name="quantity" class="select-quantity khalab-pdp-qty-select">
                                                {% if product.selected_product.is_infinite or product.selected_product.quantity > 100 %}
                                                    {% set maxQuantity = 100 %}
                                                {% else %}
                                                    {% set maxQuantity = product.selected_product.quantity %}
                                                {% endif %}
                                                {% for n in range(1, maxQuantity + 1) %}
                                                    <option value="{{ n }}" {% if n == 1 %}selected{% endif %}>{{ n }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                {% endif %}

                                <div class="section-out-of-stock-notify-me {% if not can_buy %}d-block{% else %}d-none{% endif %}">
                                    <div class="khalab-pdp-notify">
                                        <h4 class="product-title">{{ _("This product is out of stock") }}</h4>
                                        <form>
                                            <input type="hidden" class="send-notify-product-id" value="{{ product.selected_product.id }}">
                                            <div class="form-group form-notify-me">
                                                <h4>{{ _("Notify me when product is available") }}</h4>
                                                <input class="form-control send-notify-name" value="" type="text" placeholder="{{ _('Enter your name') }}" />
                                                <input class="form-control send-notify-email" type="email" value="" placeholder="{{ _('Enter your email') }}" />
                                                <div class="d-flex form-notify-me-phone-row">
                                                    <input class="form-control send-notify-country-key" type="number" placeholder="966" maxlength="4" />
                                                    <input class="form-control send-notify-phone" type="number" value="" placeholder="{{ _('Enter your phone (Optional)') }}" maxlength="10" />
                                                </div>
                                                <div class="form-notify-me-submit-button-row">
                                                    <button type="button" class="btn btn-primary btn-send-notify" onclick="sendProductNotifyMe()">
                                                    {% set loader_size = 'sm' %}{% set loader_variant = 'dark' %}{% set loader_class = 'send-notify-progress d-none' %}{% include 'components/khalab-loader.jinja' %}
                                                    {{ _("Send") }}
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </form>

                            {% if product.product_class == 'dynamic_bundle' %}
                                {% include 'vitrin:products/bundle-products.jinja' %}
                            {% endif %}

                            <div>
                                <span id="product-view-add-to-cart"></span>
                            </div>

                    </div>
                </div>
            </section>


            {% if product.bundle_offer %}
            <section class="bundle-offer-details-section mt-5">
                <div class="d-flex align-items-center">
                    <div class="description-icon">
                        <span class="icon-gift"></span>
                    </div>
                    <div class="description-title">
                        <div class="bundle-offer-title">{{ product.bundle_offer.name }}</div>
                        <div class="bundle-offer-title-description">{{ product.bundle_offer.description }}</div>
                    </div>
                </div>
                <div class="description-paragrah">
                    <div class="bundle-offer-products">
                        <div class="row bundle-offer-details-products">
                            {% for product in product.bundle_offer.products.results[:5] %}
                                <div class="prod-col prod-col-tb">
                                    {% set product=product %}{% set index=loop.index0 %}{% include 'components/product-card.jinja' %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% if product.bundle_offer and product.bundle_offer.products and product.bundle_offer.products.results | length > 5 %}
                    <div class="bundle-offer-more">
                        <a href="#" data-toggle="modal" data-target=".bd-example-modal-lg">{{ _("Display all products") }}</a>
                    </div>
                    {% endif %}
                </div>
            </section>
            {% endif %}

            {% include 'vitrin:products/grouped-product.jinja' %}

            {% if product.metafields %}
                <section id="product-description" class="mt-5">
                    <div class="d-flex align-items-center">
                        <div class="description-icon">
                            <span class="icon-fact_check_black"></span>
                        </div>
                        <div class="description-title">
                           {{ _("product information") }}
                        </div>
                    </div>
                    <div class="description-paragrah text-justify description-text-clear">
                          {% set entity = product %}
                          {% include 'vitrin:shared/metafields.jinja' %}
                    </div>
                </section>
            {% endif %}

            {% if product.description %}
                <section id="product-description" class="mt-5">
                    <div class="d-flex align-items-center">
                        <div class="description-icon">
                            <span class="icon-fact_check_black"></span>
                        </div>
                        <div class="description-title">
                            {{ _("product description") }}
                        </div>
                    </div>
                    {% autoescape false %}
                        <div class="description-paragrah text-justify description-text-clear">
                            {{ product.description }}
                        </div>
                    {% endautoescape %}
                </section>
            {% endif %}


            {% if store.settings.products.reviews_enabled %}
                <section class="mt-5 review-details">
                    <div>
                        <div class="d-flex flex-wrap align-items-center" style="width: 100%">
                            <div class="description-icon">
                                <span class="icon-reviews_black"></span>
                            </div>
                            <div class="description-title">
                                {{ _("Reviews") }}
                            </div>
                            {% if product.rating %}
                            <div class="rating-section">
                                    <div>
                                        {% set rating=product.rating.average %}{% include 'components/rating-stars.jinja' %}
                                        <span class="product-card-rating-count">({{ product.rating.total_count }})</span>
                                    </div>
                            </div>
                            {% endif %}

                            &nbsp;
                            <!-- Button trigger modal -->
                            {% if session.is_guest %}
                            <a href="/auth/login?redirect_to={{ url_for('add_product_review', slug=product.id) }}" class="btn btn-primary add-review-btn" onclick="event.preventDefault(); handleLoginAction('{{ url_for('add_product_review', slug=product.id) }}'); return false;"><span class="icon-add_circle"></span>{{ _("Add Comment ") }} </a>
                            {% else %}
                            <a href="{{ url_for('add_product_review', slug=product.slug) }}" class="btn btn-primary add-review-btn" id="add-review-btn"><span class="icon-add_circle"></span>{{ _("Add Comment ") }}</a>
                            {% endif %}
                        </div>
                        <div class="reviews-break-down-div description-paragrah">
                            <div class="d-flex align-items-center mt-3 mb-4">
                                {% if product.rating %}
                                <h4 class="rating-average">{{ product.rating.average }}</h4>
